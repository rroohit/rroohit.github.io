---
import '@/styles/global.css';
import SEO from '@/components/SEO.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Icon from '@/components/Icon.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const { title, description, image, article } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Blog" href="/rss.xml" />

    <!-- No-flash theme: set class before first paint -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const dark = stored
          ? stored === 'dark'
          : window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', dark);
        document.documentElement.classList.add('js');
      })();
    </script>

    <SEO title={title} description={description} image={image} article={article} />
  </head>
  <body class="min-h-screen">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-[var(--accent)] focus:px-4 focus:py-2 focus:text-[var(--accent-contrast)]"
      >Skip to content</a
    >
    <Header />
    <main id="main" class="pt-16">
      <slot />
    </main>
    <Footer />

    <a
      href="#top"
      id="back-to-top"
      class="pointer-events-none fixed bottom-6 right-6 z-40 inline-flex h-10 w-10 translate-y-4 items-center justify-center rounded-full border border-[var(--border)] bg-[var(--bg-elevated)] text-[var(--text-muted)] opacity-0 shadow-lg transition hover:text-[var(--text)]"
      aria-label="Back to top"
    >
      <Icon name="arrow-up" class="h-5 w-5" />
    </a>

    <script>
      // Back-to-top visibility
      const btt = document.getElementById('back-to-top');
      window.addEventListener(
        'scroll',
        () => {
          const show = window.scrollY > 600;
          btt?.classList.toggle('opacity-0', !show);
          btt?.classList.toggle('translate-y-4', !show);
          btt?.classList.toggle('pointer-events-none', !show);
        },
        { passive: true }
      );

      // Scroll-reveal
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
