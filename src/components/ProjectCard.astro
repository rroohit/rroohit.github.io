---
import { type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Icon from './Icon.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { data, id } = project;

const statusLabel: Record<string, string> = {
  shipped: 'Shipped',
  'open-source': 'Open source',
  'in-progress': 'In progress',
  archived: 'Archived',
};

const initials = data.title
  .split(' ')
  .slice(0, 2)
  .map((w) => w[0])
  .join('');
---

<article
  class="reveal group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--bg-soft)] transition hover:border-[var(--accent)] hover:shadow-lg"
>
  {
    data.cover ? (
      <a href={`/projects/${id}/`} class="block overflow-hidden">
        <Image
          src={data.cover}
          alt={data.title}
          width={640}
          height={360}
          class="aspect-video w-full object-cover transition duration-500 group-hover:scale-[1.03]"
        />
      </a>
    ) : (
      <a
        href={`/projects/${id}/`}
        class="relative flex aspect-video items-center justify-center overflow-hidden bg-[var(--bg)]"
      >
        <div
          class="absolute inset-0 opacity-90"
          style="background-image: radial-gradient(circle at 30% 20%, var(--color-accent-500), transparent 55%), radial-gradient(circle at 80% 80%, var(--color-accent-700), transparent 50%);"
          aria-hidden="true"
        />
        <span class="relative font-mono text-2xl font-bold text-white/90">{initials}</span>
      </a>
    )
  }
  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-center gap-2">
      <span
        class="rounded-md border border-[var(--border)] bg-[var(--bg)] px-2 py-0.5 font-mono text-[11px] uppercase tracking-wide text-[var(--accent)]"
        >{statusLabel[data.status] ?? data.status}</span
      >
      {data.period && <span class="text-xs text-[var(--text-faint)]">{data.period}</span>}
    </div>

    <h3 class="mt-3 text-lg font-semibold">
      <a href={`/projects/${id}/`} class="after:absolute after:inset-0">{data.title}</a>
    </h3>
    {data.role && <p class="mt-0.5 text-xs text-[var(--text-faint)]">{data.role}</p>}
    <p class="mt-2 flex-1 text-sm text-[var(--text-muted)]">{data.summary}</p>

    <div class="mt-4 flex flex-wrap gap-1.5">
      {
        data.tech.slice(0, 5).map((t) => (
          <span class="rounded-md bg-[var(--bg)] px-2 py-0.5 font-mono text-[11px] text-[var(--text-muted)]">
            {t}
          </span>
        ))
      }
    </div>

    <div class="relative z-10 mt-4 flex items-center gap-3 text-[var(--text-muted)]">
      {
        data.links.github && (
          <a
            href={data.links.github}
            target="_blank"
            rel="noopener"
            aria-label="Source code"
            class="transition hover:text-[var(--text)]"
          >
            <Icon name="github" class="h-[18px] w-[18px]" />
          </a>
        )
      }
      {
        data.links.playstore && (
          <a
            href={data.links.playstore}
            target="_blank"
            rel="noopener"
            aria-label="Play Store"
            class="transition hover:text-[var(--text)]"
          >
            <Icon name="play" class="h-[18px] w-[18px]" />
          </a>
        )
      }
      {
        data.links.live && (
          <a
            href={data.links.live}
            target="_blank"
            rel="noopener"
            aria-label="Live"
            class="transition hover:text-[var(--text)]"
          >
            <Icon name="external" class="h-[18px] w-[18px]" />
          </a>
        )
      }
      <span class="ml-auto inline-flex items-center gap-1 text-xs font-medium text-[var(--accent)]">
        Details <Icon name="arrow-right" class="h-3.5 w-3.5" />
      </span>
    </div>
  </div>
</article>
