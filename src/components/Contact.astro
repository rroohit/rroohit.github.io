---
import SectionHeading from './SectionHeading.astro';
import Icon from './Icon.astro';
import { socials } from '@/data/site';
---

<section id="contact" class="container-page scroll-mt-20 py-16 sm:py-20">
  <SectionHeading eyebrow="Contact" title="Let's connect" align="center" />
  <p class="reveal mx-auto mt-4 max-w-xl text-center text-[var(--text-muted)]">
    Have a role, a project, or just want to talk Kotlin and system design? Reach out.
  </p>

  <div class="reveal mx-auto mt-10 grid max-w-2xl gap-3">
    {
      socials.map((s) => (
        <a
          href={s.url}
          target={s.icon === 'mail' ? undefined : '_blank'}
          rel="noopener"
          class="flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--bg-soft)] p-4 transition hover:border-[var(--accent)]"
        >
          <span class="grid h-10 w-10 place-items-center rounded-lg bg-[var(--bg)] text-[var(--accent)]">
            <Icon name={s.icon} class="h-5 w-5" />
          </span>
          <span>
            <span class="block text-sm font-medium">{s.name}</span>
            <span class="block text-xs text-[var(--text-muted)]">{s.label}</span>
          </span>
          <Icon name="arrow-up-right" class="ml-auto h-4 w-4 text-[var(--text-faint)]" />
        </a>
      ))
    }
  </div>
</section>
