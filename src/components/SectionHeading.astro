---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, align = 'left' } = Astro.props;
---

<div class={`reveal ${align === 'center' ? 'text-center' : ''}`}>
  {
    eyebrow && (
      <p class="mb-2 font-mono text-xs font-semibold uppercase tracking-[0.2em] text-[var(--accent)]">
        {eyebrow}
      </p>
    )
  }
  <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">{title}</h2>
  <div
    class={`mt-4 h-px w-16 bg-gradient-to-r from-[var(--accent)] to-transparent ${
      align === 'center' ? 'mx-auto' : ''
    }`}
  >
  </div>
</div>
